@startuml
skinparam classAttributeIconSize 0
skinparam roundcorner 10
skinparam nodesep 50
skinparam ranksep 50

enum TeacherType { 
    TUTOR, LECTOR, 
    SENIOR_LECTOR, 
    PROFESSOR 
}
enum ManagerType { 
    OR, 
    DEPARTMENT_HEAD, 
    DEAN 
}
enum CourseType { 
    MAJOR, 
    MINOR, 
    FREE_ELECTIVE 
}
enum LessonType { 
    LECTURE, 
    PRACTICE 
}
enum MarkType { 
    FIRST_ATTESTATION, 
    SECOND_ATTESTATION, 
    FINAL_EXAM 
}
enum RequestStatus { 
    NEW, 
    VIEWED, 
    ACCEPTED, 
    REJECTED, 
    DONE 
}
enum Urgency { 
    LOW, 
    MEDIUM, 
    HIGH 
}

abstract class User {
    - userId: int
    - firstname: String
    - lastname: String
    - password: Password
    - email: String
    - phoneNumber: String
    - registrationDate: Date
    + login(): boolean
    + logout(): boolean
    + viewNews(): void
}

class Student {
    - studentId: int
    - yearOfStudy: int
    - gpa: double
    - credits: int
    + registerForCourse(c: Course): void
    + viewCourses(): void
    + viewMarks(): void
    + viewTranscript(): void
}

class GraduateStudent {
    - supervisor: Researcher
    - diplomaProjects: List<ResearchPaper>
}

abstract class Employee {
    - employeeId: int
    - position: String
    - messages: List<Message>
    + sendMessage(m: Message): void
    + receiveMessage(m: Message): void
    + viewMessages(): void
}

class Teacher {
    - teacherId: int
    - teacherType: TeacherType
    + addCourse(c: Course): void
    + removeCourse(c: Course): void
    + addLesson(l: Lesson): void
    + viewCourses(): void
    + viewStudents(): void
    + assignMark(s: Student, c: Course, m: Mark): void
    + sendComplaint(s: Student, u: Urgency): void
}

class Manager {
    - managerId: int
    - managerType: ManagerType
    + assignCourseToTeacher(c: Course, t: Teacher): void
    + approveRegistration(s: Student, c: Course): void
    + createReport(): void
    + manageNews(): void
}

class TechSupporter {
    - supportId: int
    + viewRequests(): void
    + acceptRequest(r: TechRequest): void
    + rejectRequest(r: TechRequest): void
    + completeRequest(r: TechRequest): void
}

class Admin {
    - adminId: int
    + addUser(u: User): void
    + removeUser(u: User): void
    + updateUser(u: User): void
    + viewLogs(): void
}

' --- RESEARCHER DECORATOR ---
abstract class UserDecorator {
    # decoratedUser: User
    + UserDecorator(u: User)
}

class Researcher {
    - papers: List<ResearchPaper>
    - projects: List<ResearchProject>
    + calculateHIndex(): int
    + printPapers(c: Comparator): void
    + joinProject(p: ResearchProject): void
}

class Course {
    - courseId: int
    - name: String
    - credits: int
    - courseType: CourseType
    + addStudent(s: Student): void
    + removeStudent(s: Student): void
    + assignTeacher(t: Teacher): void
    + viewCourseInfo(): void
}

class Lesson {
    - lessonId: int
    - lessonType: LessonType
    - date: Date
    - topic: String
    + assignStudent(s: Student): void
    + viewStudents(): void
}

class Mark {
    - value: double
    - markType: MarkType
    + calculateTotal(): double
}

class Message {
    - sender: Employee
    - content: String
    - date: Date
}

class TechRequest {
    - description: String
    - status: RequestStatus
}

class ResearchPaper {
    - title: String
    - citations: int
    - pages: int
    - doi: String
    - datePublished: Date
    + getCitation(format: String): String
}

class ResearchProject {
    - topic: String
    + addParticipant(r: Researcher): void
}

User <|-- Student
Student <|-- GraduateStudent
User <|-- Employee
Employee <|-- Teacher
Employee <|-- Manager
Employee <|-- TechSupporter
Employee <|-- Admin

User <|-- UserDecorator
UserDecorator <|-- Researcher
UserDecorator o-- User : "wraps"

Student "1" -- "*" Mark : "receives"
Course "1" *-- "*" Mark : "has"
Course "1" *-- "*" Lesson : "consists of"
Teacher "*" -- "*" Course : "teaches"
Manager "1" -- "*" Course : "manages"
Employee "1" -- "*" Message : "sends/receives"
TechSupporter "1" -- "*" TechRequest : "handles"

Researcher "1" -- "*" ResearchPaper : "authors"
Researcher "*" -- "*" ResearchProject : "participates in"

@enduml