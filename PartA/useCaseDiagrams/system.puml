@startuml
skinparam theme plain
skinparam packageStyle rectangle
skinparam roundcorner 10
skinparam shadowing false
skinparam defaultFontName "Segoe UI"

skinparam actor {
    BackgroundColor #FFEBEE
    BorderColor #C62828
}
skinparam usecase {
    BackgroundColor #FAFAFA
    BorderColor #37474F
    ArrowColor #546E7A
}

left to right direction

actor "Admin" as A
actor "TechSupporter" as TS
actor "Manager" as M

rectangle "Admin & Support Subsystem" {
    usecase "User Management" as UserMgmt
    usecase "Logs" as Logs
    usecase "Requests" as Requests

    A -- UserMgmt : <<Add User>>
    A -- UserMgmt : <<Update User>>
    A -- UserMgmt : <<Remove User>>
    A -- Logs : <<View Logs>>

    TS -- Requests : <<Accept Request>>
    TS -- Requests : <<Reject Request>>
    TS -- Requests : <<Mark Request as Done>>
    
    M -- Requests : <<View Requests>>
}
@enduml